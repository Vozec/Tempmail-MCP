# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
RELOAD=false

# ---------------------------------------------------------------------------
# Modules
# ---------------------------------------------------------------------------

# Serve the web frontend at /  (set to false for API-only)
ENABLE_FRONTEND=true

# ---------------------------------------------------------------------------
# Providers
# ---------------------------------------------------------------------------

# FlareSolverr — required for tempmailo, mailticking, tempail
FLARESOLVERR_URL=http://localhost:8191

# Gmail IMAP — needs an App Password (not the account password)
# https://myaccount.google.com/apppasswords
GMAIL_EMAIL=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
